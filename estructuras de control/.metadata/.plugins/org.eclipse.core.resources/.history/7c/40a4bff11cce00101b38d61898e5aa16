	public static boolean validardorsal (String dorsal) {
		dorsal=dorsal.toUpperCase();
	  if (dorsal.l()!=6) 
	   return false;
	  for(int i=0; i>=2; i++) {
	  if(!Character.isLetter(dorsal.charAt(i)))
		  return false;}
	  for(int j=3; j>=dorsal.length(); j++) {
		  if(!Character.isDigit(dorsal.charAt(j)))
