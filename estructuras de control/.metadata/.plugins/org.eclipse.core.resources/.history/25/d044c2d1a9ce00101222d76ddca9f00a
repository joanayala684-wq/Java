package Paquetes_Excepciones;

import java.time.format.DateTimeFormatter;
import java.util.Scanner;

public class ejer5 {
	static Scanner sc;
	public static void main(String[] args) {
		// TODO Auto-generated method stub
/*Lee una cadena e intenta extraer una fecha con el formato dd/mm/yyyy de su
contenido (la cadena puede tener otras cosas, por ejemplo “Yo nací el 29/02/1998”).
Los casos en los que no se encuentre ninguna fecha o se encuentren varias deberán
manejarse con excepciones.*/
		sc = new Scanner(System.in);
		String cadena;
		boolean correcto=false;
		int cont=0;
	
		do {
			System.out.println("introduce una cadena");
			cadena=sc.nextLine();
			if(cadena.isEmpty()){
				System.out.println("debe rellenar la cadena");}
			else
				correcto=true;
		}while(!correcto);
		cont=BuscaFecha(cadena);
		System.out.println("se han encontrado un numero de fechas de "+ cont );
	}
	public static int BuscaFecha (String cadena) {
		String regex="\\d{2}/\\d{2}/\\d{4}";
		int cont=0;
		if(cadena.matches(regex)) {
			System.out.println("la cadena contiene una fecha");
			cont++;}
		
		return cont;
		
	}
}
