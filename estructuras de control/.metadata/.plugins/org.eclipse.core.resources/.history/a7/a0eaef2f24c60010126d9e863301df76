		nombre=nombre.substring(0);
		if(apellido.length()>2) 
			parteapellido=apellido.substring(0,2);
		else 
			if(segundo.length()>2 )
				parteapellido=segundo.substring(0, 2);
			else 
				if(apellido.length()>segundo.length())
					parteapellido=apellido;
				else 
					parteapellido=segundo;
		
		return codigo;
	}
	
}

