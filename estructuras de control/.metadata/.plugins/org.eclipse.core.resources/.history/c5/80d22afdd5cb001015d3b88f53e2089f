public static LocalDate GenerarFechaSecret  () {
	Random r=new Random();
	String fechasecretaS;
	LocalDate fechasecreta;
	int dias=0;
	DateTimeFormatter patron=DateTimeFormatter.ofPattern("dd/MM/yyyy");
	
	int años =r.nextInt(1900, 2025)+1;
	int meses =r.nextInt(12)+1;
	if (meses == 1 || meses ==3|| meses ==5|| meses==7 || meses==8|| meses==10|| meses==12  ) {
		dias = r.nextInt(31)+1;
	}
	else 
		if (meses == 4 || meses ==6|| meses ==9|| meses==11  ) {
		dias = r.nextInt(30)+1;
	}
		else if (meses==2) {
		 dias = r.nextInt(28)+1;}
	
	fechasecretaS=dias+ "/"+ meses+ "/"+años;
	fechasecreta=LocalDate.parse(fechasecretaS, patron);
	return fechasecreta;
	
