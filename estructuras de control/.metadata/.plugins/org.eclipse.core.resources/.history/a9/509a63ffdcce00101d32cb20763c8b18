package Paquetes_Excepciones;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.Scanner;

public class ejer5 {
	static Scanner sc;
	public static void main(String[] args) {
		// TODO Auto-generated method stub
/*Lee una cadena e intenta extraer una fecha con el formato dd/mm/yyyy de su
contenido (la cadena puede tener otras cosas, por ejemplo “Yo nací el 29/02/1998”).
Los casos en los que no se encuentre ninguna fecha o se encuentren varias deberán
manejarse con excepciones.*/
		sc = new Scanner(System.in);
		String cadena;
		boolean correcto=false;
		LocalDate fecha=null;
		int cont=0;
	
	
			System.out.println("introduce una cadena");
			cadena=sc.nextLine();

		fecha=BuscaFecha(cadena);
		System.out.println("se han encontrado un numero de fechas de "+ fecha );
	}
	public static LocalDate BuscaFecha (String cadena) {
		DateTimeFormatter patron=DateTimeFormatter.ofPattern("dd/MM/yyyy");
		LocalDate fecha=null;
		for(int i=0; i<cadena.length();i++)
		if(Character.isDigit(cadena.charAt(i)))
			if(i+10<=cadena.length()) {
				String fechaS=cadena.substring(i, i+10);
				System.out.println("posible:" + fechaS);
				fecha=LocalDate.parse(fechaS, patron);
				System.out.println("la fecha es "+ patron.format(fecha));
			}
		
		return fecha;
		
	}
}
