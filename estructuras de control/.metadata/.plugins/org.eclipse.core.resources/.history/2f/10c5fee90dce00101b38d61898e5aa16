package desafios;

import java.util.Random;

public class ejer4 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		String clave="";
		clave=GenerarCodigo();
		System.out.println(clave);
	}

	public static String  GenerarCodigo() {
		String cadena="RAMVNI", primer, segun, tercer, cuarto, secreto;
		Random r = new Random();
		int digit1, digit2, digit3, digit4;
		primer=cadena.substring(0, digit1=r.nextInt(5));
		segun=cadena.substring(digit2=r.nextInt(5));
		tercer=cadena.substring(digit3=r.nextInt(5));
		cuarto=cadena.substring(digit4=r.nextInt(5));
		secreto=primer+segun+tercer+cuarto;
		return secreto;
	}
}
